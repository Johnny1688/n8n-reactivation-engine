    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const input = $json;\nconst messages = Array.isArray(input.messages) ? input.messages : [];\n\n// 去重（只在当前客户内部）\nconst seen = new Set();\n\nconst uniqueMessages = messages.filter(m => {\n  const key = `${m.role || ''}__${m.message || ''}__${m.message_time || ''}`;\n  \n  if (seen.has(key)) return false;\n  seen.add(key);\n  return true;\n});\n\nreturn {\n  ...input,\n  messages: uniqueMessages,\n  original_message_count: messages.length,\n  deduplicated_message_count: uniqueMessages.length\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1504,
        -80
      ],
      "id": "9b02d050-4c62-45f3-ba42-59d00a470262",
      "name": "消息去重"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH top50 AS (\n  SELECT \n    *,\n    ROW_NUMBER() OVER () AS original_order\n  FROM followup_candidates LIMIT 50\n),\nenriched AS (\n  SELECT \n    top50.*,\n    phone_lookup.customer_phone,\n    CASE\n      WHEN top50.customer_name ~ '澳大利亚|澳洲|新西兰|菲律宾' THEN 1\n      WHEN phone_lookup.customer_phone LIKE '+61%' THEN 1\n      WHEN phone_lookup.customer_phone LIKE '+64%' THEN 1\n      WHEN phone_lookup.customer_phone LIKE '+63%' THEN 1\n      ELSE 2\n    END AS country_priority\n  FROM top50\n  LEFT JOIN LATERAL (\n    SELECT customer_phone FROM contacts \n    WHERE contacts.project_key = top50.project_key\n      AND customer_phone IS NOT NULL\n    LIMIT 1\n  ) phone_lookup ON true\n)\nSELECT * FROM enriched\nORDER BY country_priority, original_order;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        384,
        48
      ],
      "id": "a5410624-4b20-4269-91bc-ecba76c56e28",
      "name": "Load today_followups_填写数量",
      "credentials": {
        "postgres": {
          "id": "P2YAWZISt6YM3EZr",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const row = $json || {};\nconst rawMessages = Array.isArray(row.messages) ? row.messages : [];\n\n// 1) 按时间排序\nconst messages = [...rawMessages].sort((a, b) => {\n  const ta = new Date(a.message_time || 0).getTime();\n  const tb = new Date(b.message_time || 0).getTime();\n  return ta - tb;\n});\n\n// 2) 最后一条客户消息\nconst lastCustomerObj = [...messages].reverse().find(m => m.role === 'customer') || null;\nconst lastCustomerMessage = lastCustomerObj?.message || '';\nconst lastCustomerMessageTime = lastCustomerObj?.message_time || null;\n\n// 3) 最后一条我方消息\nconst lastMyObj = [...messages].reverse().find(m => m.role === 'me') || null;\nconst lastMyMessage = lastMyObj?.message || '';\nconst lastMyMessageTime = lastMyObj?.message_time || null;\n\n// 4) 最近消息\nconst recentMessages = messages.slice(-12);\n\n// 5) 完整对话文本\nconst cleanedFullConversation = messages\n  .map((m) => {\n    const role = m.role || 'unknown';\n    const msg = (m.message || '').toString().replace(/\\s+/g, ' ').trim();\n    return `${role}: ${msg}`;\n  })\n  .join('\\n');\n\n// 6) 最近对话文本\nconst recentConversation = recentMessages\n  .map((m) => {\n    const role = m.role || 'unknown';\n    const msg = (m.message || '').toString().replace(/\\s+/g, ' ').trim();\n    return `${role}: ${msg}`;\n  })\n  .join('\\n');\n\n// 7) 输出\nreturn {\n  json: {\n    ...row,\n    project_key: row.project_key || '',\n    customer_name: row.customer_name || row.project_key || '',\n    messages,\n    message_count: messages.length,\n    has_messages: messages.length > 0,\n    last_customer_message: lastCustomerMessage,\n    last_customer_message_time_normalized: lastCustomerMessageTime,\n    last_my_message: lastMyMessage,\n    last_my_message_time_normalized: lastMyMessageTime,\n    recent_messages: recentMessages,\n    cleaned_full_conversation: cleanedFullConversation,\n    recent_conversation: recentConversation,\n    _debug_source: 'normalize_customer_data'\n  }\n};"
      },
