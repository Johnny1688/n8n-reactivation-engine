      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "3935669e-5eec-499c-b88b-458342c4d079",
              "leftValue": "={{ $json.use_full_messages }}",
              "rightValue": "",
              "operator": {
